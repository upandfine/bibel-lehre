# Bib-Inside — Beispiel-Konfiguration
# Kopiere diese Datei zu .env.local für die lokale Entwicklung,
# und setze die Werte in Sliplane für Production.

# === Datenbank ===
# Lokal (mit docker-compose up):
DATABASE_URL=postgres://bibinside:bibinside@localhost:5432/bibinside

# Production (Sliplane Postgres-Service):
# DATABASE_URL=postgres://USER:PASS@HOST:5432/DBNAME

# === NextAuth v4 ===
# Pflichtfeld — generieren mit: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32

# Production: die echte URL eintragen, z.B. https://bib-inside.de
NEXTAUTH_URL=http://localhost:3000

# === E-Mail-Versand (Resend) ===
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM="Bib-Inside <noreply@send.bib-inside.de>"

# === App-Einstellungen ===
NEXT_PUBLIC_APP_NAME="Bib-Inside"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Magic-Link-Gültigkeit in Minuten (Default: 30)
AUTH_EMAIL_LINK_TTL_MINUTES=30

# === Seed ===
# E-Mail-Adresse, die beim ersten `pnpm db:seed` als Admin angelegt wird.
# Wenn leer, wird kein Admin angelegt.
SEED_ADMIN_EMAIL=sommer@upandfine.de
