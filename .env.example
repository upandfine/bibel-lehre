# Bib-Inside — Beispiel-Konfiguration
#
# Lokal: kopieren nach .env.local
# Production (Sliplane): einzeln im Service-Setting eintragen
# ────────────────────────────────────────────────────────────

# === Datenbank ===
# Lokal (mit docker-compose up):
DATABASE_URL=postgres://bibinside:bibinside@localhost:5432/bibinside
#
# Production: Sliplane-Postgres-Service anlegen, dann seinen
# Internal-Hostname statt "localhost" eintragen — z. B.
# DATABASE_URL=postgres://USER:PASS@bibinside-db.internal:5432/bibinside

# === NextAuth v4 ===
# Pflichtfeld — generieren mit: openssl rand -base64 32
# Production: NEUEN Wert generieren, NICHT den lokalen verwenden.
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32
#
# Lokale Dev-URL (fester Port 3050).
# Production: vollständige öffentliche URL inklusive https, z. B.
# NEXTAUTH_URL=https://bib-inside.sliplane.app  (oder eigene Domain)
NEXTAUTH_URL=http://localhost:3050

# === E-Mail-Versand (Resend) ===
# Lokal leer lassen → Magic-Link wird in die Server-Konsole geloggt.
# Production: echten Key aus Resend-Dashboard eintragen.
RESEND_API_KEY=
EMAIL_FROM="Bib-Inside <noreply@send.bib-inside.de>"

# === App-Einstellungen ===
NEXT_PUBLIC_APP_NAME="Bib-Inside"
# Lokal: localhost:3050. Production: identisch zu NEXTAUTH_URL.
NEXT_PUBLIC_APP_URL=http://localhost:3050

# Magic-Link-Gültigkeit in Minuten (Default: 30)
AUTH_EMAIL_LINK_TTL_MINUTES=30

# === Seed ===
# E-Mail-Adresse, die beim ersten `pnpm db:seed` als Admin angelegt wird.
# Wenn leer, wird kein Admin angelegt.
SEED_ADMIN_EMAIL=sommer@upandfine.de

# === Production-Hinweis ===
# In Sliplane setzt der Container automatisch:
#   - PORT (Range 8080–65535) → wird vom Next-Server gelesen
#   - HOSTNAME=0.0.0.0 (im Dockerfile als Default gesetzt)
# Diese beiden Variablen NICHT manuell überschreiben.
